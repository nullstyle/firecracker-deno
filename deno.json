{
  "name": "@nullstyle/firecracker",
  "version": "0.1.0-alpha.0",
  "license": "Apache-2.0",
  "exports": {
    ".": "./mod.ts",
    "./client": "./src/api/mod.ts",
    "./types": "./src/api/types.ts",
    "./testing": "./testing/mod.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "@std/path": "jsr:@std/path@^1",
    "@std/yaml": "jsr:@std/yaml@^1",
    "openapi-typescript": "npm:openapi-typescript@^7",
    "swagger2openapi": "npm:swagger2openapi@^7"
  },
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check .",
    "test": "deno test --allow-read --allow-write --allow-net --allow-run --allow-env tests/unit/ tests/fake/",
    "test:integration": "deno test -A tests/integration/",
    "spec:fetch": "deno run --allow-net --allow-write=spec tools/fetch-spec.ts",
    "codegen": "deno run --allow-read --allow-write --allow-net --allow-env tools/codegen.ts",
    "spec:drift": "deno run --allow-read --allow-write --allow-net --allow-env tools/check-spec-drift.ts"
  },
  "fmt": {
    "exclude": ["spec/"]
  },
  "lint": {
    "exclude": ["src/generated/"]
  },
  "publish": {
    "include": [
      "mod.ts",
      "src/**",
      "testing/**",
      "README.md",
      "LICENSE",
      "deno.json"
    ]
  }
}
