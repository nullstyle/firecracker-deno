{
  "name": "@nullstyle/firecracker",
  "version": "0.1.0-alpha.0",
  "license": "Apache-2.0",
  "exports": {
    ".": "./mod.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1"
  },
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check .",
    "test": "deno test tests/unit/"
  },
  "fmt": {
    "exclude": ["spec/"]
  },
  "lint": {
    "exclude": ["src/generated/"]
  },
  "publish": {
    "include": [
      "mod.ts",
      "src/**",
      "testing/**",
      "README.md",
      "LICENSE",
      "deno.json"
    ]
  }
}
